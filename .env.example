# ─── HeartSync — Environment Variables ──────────────────────────────────────
# Copy this file to `.env` (or load these via `set` / `export`) before running
# `python app.py`. Lines starting with `#` are ignored.

# ── Google Fit (smartwatch bridge) ──
# Get these from Google Cloud Console → APIs & Services → Credentials →
# Create Credentials → OAuth client ID → Web application
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Default redirect URI — change ONLY if you run on a different host or port.
# This MUST match exactly the URI you added under
# "Authorized redirect URIs" in your OAuth client settings.
GOOGLE_REDIRECT_URI=http://localhost:5000/oauth/google/callback

# ── SMTP for emergency alert emails (optional but recommended) ──
# Use a Gmail App Password (https://myaccount.google.com/apppasswords) —
# regular passwords will not work.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=HeartSync Alerts <noreply@heartsync.local>

# ── Optional: AI food image recognition ──
# If set, /food_log photo upload uses Claude Vision to identify the meal.
ANTHROPIC_API_KEY=

# ── Flask secret (any random string is fine) ──
SECRET_KEY=change-me-to-a-random-string
